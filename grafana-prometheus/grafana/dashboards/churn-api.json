  },
  "description": "Dashboard de monitoramento da API de previsão de churn (FastAPI + Prometheus). Painéis de KPIs operacionais, comparativos Customer×Churner por gênero/plano e série temporal por faixa de risco.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "KPIs",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Modelo carregado",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 3, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "OFF", "color": "red"}}},
            {"type": "value", "options": {"1": {"text": "ON", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]}
        },
        "overrides": []
      },
      "targets": [
        {"expr": "churn_api_model_loaded", "legendFormat": "model_loaded", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Versão do modelo",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 5, "x": 3, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/^version$/", "values": false},
        "textMode": "value"
      },
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "targets": [
        {"expr": "churn_api_model_info", "format": "table", "instant": true, "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Customer Profile (total)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value"
      },
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "green"}, "decimals": 0}, "overrides": []},
      "targets": [
        {"expr": "sum(churn_api_predictions_total)", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Churner Profile (predições=1)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value"
      },
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "red"}, "decimals": 0}, "overrides": []},
      "targets": [
        {"expr": "sum(churn_api_predictions_total{churn_prediction=\"1\"})", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Taxa de churn predita (1h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
