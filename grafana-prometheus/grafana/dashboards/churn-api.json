            {"color": "yellow", "value": 0.20},
            {"color": "orange", "value": 0.35},
            {"color": "red", "value": 0.50}
          ]}
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(churn_api_predictions_total{churn_prediction=\"1\"}[1h])) / clamp_min(sum(increase(churn_api_predictions_total[1h])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
