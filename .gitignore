# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.egg-info/

# Virtual environments
.env
.venv/
.venv-2/
.venv-2
venv-teste/
ENV/
env/

# Jupyter Notebook
.ipynb_checkpoints

# IDEs
.vscode/
.idea/

# Data files — formatos binários de dados brutos e serializados
*.csv
*.h5
*.pkl
*.sqlite
# Artefatos serializados (sklearn pipelines, arrays de treino/teste etc.)
# Recriados automaticamente ao executar os notebooks ou scripts de exportação
*.joblib

# ...mas permite commitar o dataset base (fonte de verdade do projeto)
!data/raw/
!data/raw/telecom_churn_base.csv

# Experiment tracking — MLflow gera mlruns/ localmente a cada execução
mlruns/

# Logs de testes locais — gerados por scripts como simulate_drift.py
logs/

# Runtime temporário do MLflow — PID e log do servidor background (make mlflow-up)
.tmp/

# Claude Code
.claude/
